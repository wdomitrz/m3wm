# Sample skhd config for m3.
#
# Copy the bindings you want into ~/.skhdrc or ~/.config/skhd/skhdrc, then reload
# the running skhd service:
#
#   skhd -r
#
# Start the daemon separately:
#
#   /Users/witalis/Documents/m3wm/m3.py daemon --columns 2.5 --gap 8
#
# To test this file directly, prefer an absolute config path. If a skhd service
# is already running, stop it first instead of starting a second instance:
#
#   skhd --stop-service
#   skhd -c /Users/witalis/Documents/m3wm/skhdrc.sample

# Focus windows.
alt - h : /Users/witalis/Documents/m3wm/m3.py focus left
alt - j : /Users/witalis/Documents/m3wm/m3.py focus down
alt - k : /Users/witalis/Documents/m3wm/m3.py focus up
alt - l : /Users/witalis/Documents/m3wm/m3.py focus right

# Move the focused window.
shift + alt - h : /Users/witalis/Documents/m3wm/m3.py move left
shift + alt - j : /Users/witalis/Documents/m3wm/m3.py move down
shift + alt - k : /Users/witalis/Documents/m3wm/m3.py move up
shift + alt - l : /Users/witalis/Documents/m3wm/m3.py move right

# Layout controls.
alt - f : /Users/witalis/Documents/m3wm/m3.py fullscreen
alt - r : /Users/witalis/Documents/m3wm/m3.py retile

# Column presets.
ctrl + alt - 0x12 : /Users/witalis/Documents/m3wm/m3.py columns 1
ctrl + alt - 0x13 : /Users/witalis/Documents/m3wm/m3.py columns 2
ctrl + alt - 0x14 : /Users/witalis/Documents/m3wm/m3.py columns 3
ctrl + alt - 0x15 : /Users/witalis/Documents/m3wm/m3.py columns 2.5
ctrl + alt - 0x17 : /Users/witalis/Documents/m3wm/m3.py columns 1.7

# Daemon utilities.
ctrl + alt - s : /Users/witalis/Documents/m3wm/m3.py status
ctrl + alt - q : /Users/witalis/Documents/m3wm/m3.py stop
